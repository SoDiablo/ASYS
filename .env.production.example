# Production Environment Configuration
# Copy this file to .env for production deployment

# Database Configuration (Use your production database credentials)
DB_HOST=your-database-host.render.com
DB_PORT=5432
DB_NAME=asys_db
DB_USER=asys_user
DB_PASSWORD=your_secure_database_password

# JWT Configuration (MUST be changed for production)
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_characters_long
JWT_EXPIRY=24h

# Server Configuration
PORT=5000
NODE_ENV=production

# Demo Data Seeding (set to 'false' for production, 'true' for demo)
SEED_DEMO_DATA=false

# Email Configuration (Optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Frontend URL (for CORS - Update with your actual frontend URL)
FRONTEND_URL=https://your-frontend-app.onrender.com

# Security Settings
# Uncomment and configure if needed
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
