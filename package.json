{
  "name": "asys-smart-building-system",
  "version": "1.0.0",
  "description": "ASYS Smart Building Management System - Full Stack Application",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "backend": "node backend/server.js",
    "frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "cd frontend && npm install && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "heroku-postbuild": "cd frontend && npm install && npm run build"
  },
  "keywords": ["building-management", "smart-building", "apartment-management"],
  "author": "CodeForge Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.13.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
